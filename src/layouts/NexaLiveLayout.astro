---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: string;
  dir?: string;
  keywords?: string;
}

const {
  title,
  description = "NexaLive - Enterprise Communication Platform | Cloud PBX, Push-to-Talk, Encrypted Messaging",
  ogImage = "/images/og-nexalive.png",
  lang = "en",
  dir = "ltr",
  keywords = "cloud PBX, push-to-talk, PTT, walkie talkie, video PTT, encrypted messaging, VoIP, team communication, lone worker, SOS, mesh network",
} = Astro.props;

const canonical = Astro.url.href;

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "NexaLive",
  applicationCategory: "CommunicationApplication",
  operatingSystem: "Web, iOS, Android, Windows, Mac",
  description: description,
  url: "https://nexalive.ai",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  author: {
    "@type": "Organization",
    name: "TexaCore Solutions",
    url: "https://texacore.com",
  },
  featureList: [
    "Cloud PBX with IVR & Call Routing",
    "Push-to-Talk (PTT) with HD Audio",
    "Video PTT - World's First",
    "End-to-End Encrypted Messaging",
    "SOS & GPS Emergency System",
    "Lone Worker Protection",
    "NexaMesh Offline Network",
    "AI Call Analytics (NexaBrain)",
    "Works where VoIP is blocked",
  ],
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "NexaLive",
  url: "https://nexalive.ai",
  logo: "https://nexalive.ai/images/nexalive-logo.png",
  sameAs: [],
};
---

<!DOCTYPE html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- ============ ANTI-FOUC THEME SCRIPT ============ -->
    <script is:inline>
      (function() {
        try {
          var theme = localStorage.getItem('nexa-theme') || 'system';
          var resolved = theme;
          if (theme === 'system') {
            resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          var cl = document.documentElement.classList;
          if (resolved === 'dark') { cl.add('dark'); cl.remove('light'); }
          else { cl.add('light'); cl.remove('dark'); }
          document.documentElement.setAttribute('data-theme', resolved);
        } catch(e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- ============ PRIMARY SEO ============ -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical} />

    <!-- ============ OPEN GRAPH ============ -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="NexaLive" />
    <meta property="og:locale" content={lang === 'ar' ? 'ar_SA' : 'en_US'} />

    <!-- ============ TWITTER CARD ============ -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- ============ ROBOTS ============ -->
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- ============ FONTS ============ -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=Noto+Sans+Arabic:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- ============ FAVICON ============ -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- ============ SCHEMA.ORG ============ -->
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>

    <!-- ============ NEXA STYLES ============ -->
    <style is:global>
      /* ═══ Ajax-Inspired Design System ═══ */
      :root {
        /* Backgrounds */
        --bg-primary: #FFFFFF;
        --bg-secondary: #F5F5F7;
        --bg-card: #FAFAFA;
        --bg-card-hover: #F0F0F2;
        --bg-dark-section: #0A0A0A;
        --bg-feature-card: #EFEFEF;
        /* Typography */
        --text-primary: #0A0A0A;
        --text-secondary: #6E6E73;
        --text-muted: #A1A1A6;
        --text-on-dark: #FFFFFF;
        /* Brand */
        --accent-primary: #00C47A;
        --accent-primary-hover: #00A866;
        --accent-secondary: #00E5FF;
        --accent-glow: rgba(0,196,122,0.15);
        /* Borders */
        --border-light: rgba(0,0,0,0.08);
        --border-medium: rgba(0,0,0,0.12);
        --border-card: rgba(0,0,0,0.06);
        /* Gradients */
        --gradient-hero: linear-gradient(135deg, #F8FFF9 0%, #E8F5FF 50%, #F0FFF8 100%);
        --gradient-cta: linear-gradient(135deg, #00C47A, #00A0C8);
        --gradient-dark: linear-gradient(180deg, #0A0A0A 0%, #111827 100%);
        --gradient-card: linear-gradient(145deg, #FFFFFF, #F5F5F7);
      }
      html.dark {
        --bg-primary: #0a0a0f;
        --bg-secondary: #12121a;
        --bg-card: #1a1a2e;
        --bg-card-hover: #22223a;
        --bg-dark-section: #0A0A0A;
        --text-primary: #FFFFFF;
        --text-secondary: #888899;
        --text-muted: #555566;
        --text-on-dark: #FFFFFF;
        --border-light: rgba(255,255,255,0.08);
        --border-medium: rgba(255,255,255,0.12);
        --border-card: rgba(255,255,255,0.06);
        --gradient-hero: linear-gradient(135deg, #0a0a0f 0%, #0f1520 50%, #0a0f12 100%);
        --gradient-card: linear-gradient(145deg, #1a1a2e, #12121a);
      }
      /* Light mode body */
      html.light body {
        background-color: var(--bg-primary);
        color: var(--text-primary);
      }
      /* Dark mode body */
      html.dark body {
        background-color: var(--bg-primary);
        color: var(--text-primary);
      }
      /* Smooth theme transition */
      html body {
        transition: background-color 0.3s ease, color 0.3s ease;
      }
      /* Premium typography */
      html[dir='rtl'] body {
        font-family: 'IBM Plex Sans Arabic', 'Noto Sans Arabic', 'Inter', system-ui, sans-serif;
      }
      html:not([dir='rtl']) body {
        font-family: 'Inter', 'SF Pro Display', -apple-system, system-ui, sans-serif;
      }
      /* Scroll progress bar */
      .scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        background: var(--accent-primary);
        z-index: 9999;
        transition: width 0.1s;
      }
    </style>
  </head>
  <body class="min-h-screen antialiased overflow-x-hidden">
    <!-- Scroll Progress Bar -->
    <div id="scroll-progress" class="scroll-progress" style="width: 0%"></div>
    
    <slot />

    <!-- Scroll Progress Script -->
    <script is:inline>
      window.addEventListener('scroll', function() {
        var h = document.documentElement;
        var pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
        var bar = document.getElementById('scroll-progress');
        if (bar) bar.style.width = Math.min(pct, 100) + '%';
      }, { passive: true });
    </script>
